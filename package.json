{
  "name": "hospital-comparison-service",
  "version": "1.0.0",
  "description": "A comprehensive hospital comparison platform using TOPSIS algorithm",
  "main": "index.js",
  "scripts": {
    "dev": "concurrently \"npm run backend:dev\" \"npm run frontend:dev\"",
    "backend:dev": "cd backend && npm run dev",
    "frontend:dev": "cd frontend && npm run dev",
    "backend:start": "cd backend && npm start",
    "frontend:build": "cd frontend && npm run build",
    "frontend:preview": "cd frontend && npm run preview",
    "build": "npm run frontend:build",
    "start": "concurrently \"npm run backend:start\" \"npm run frontend:preview\"",
    "install:all": "npm install && cd backend && npm install && cd ../frontend && npm install",
    "clean": "rm -rf node_modules backend/node_modules frontend/node_modules",
    "reset": "npm run clean && npm run install:all"
  },
  "keywords": [
    "hospital",
    "comparison",
    "healthcare",
    "topsis",
    "decision-making",
    "react",
    "nodejs"
  ],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "concurrently": "^8.2.2"
  },
  "engines": {
    "node": ">=16.0.0",
    "npm": ">=8.0.0"
  }
}
